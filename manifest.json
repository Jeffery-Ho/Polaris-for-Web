{
  "manifest_version": 3,
  "name": "Polaris for Web",
  "version": "0.7.7",
  "version_name": "0.7.7 build 22",
  "description": "Show heading markers for supported AI web answers and jump to headings from the right edge.",
  "icons": {
    "16": "icons/gpt-voyager-icon-16.png",
    "32": "icons/gpt-voyager-icon-32.png",
    "48": "icons/gpt-voyager-icon-48.png",
    "128": "icons/gpt-voyager-icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.doubao.com/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://www.qianwen.com/*",
    "https://qianwen.com/*",
    "https://yb.tencent.com/*",
    "https://yuanbao.tencent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/gpt-voyager-icon-96.png"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://yb.tencent.com/*",
        "https://yuanbao.tencent.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://yb.tencent.com/*",
        "https://yuanbao.tencent.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
